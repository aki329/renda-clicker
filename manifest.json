{
  "manifest_version": 3,
  "name": "30 CPS Clicker",
  "version": "1.0.0",
  "description": "Hotkey controlled browser clicker with a visible ON/OFF badge.",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_title": "30 CPS Clicker",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
